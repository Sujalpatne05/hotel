{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Frontend (Vite)",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"problemMatcher": [
				"$vite"
			],
			"group": "build"
		},
		{
			"label": "Run Backend (Fastify)",
			"type": "shell",
			"command": "npm run start",
			"isBackground": true,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		}
	]
}